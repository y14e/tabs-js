{
  "name": "@y14e/tabs",
  "version": "1.3.6",
  "description": "WAI-ARIA compliant tabs pattern implementation in TypeScript",
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    }
  },
  "files": [
    "dist",
    "LICENSE",
    "README.md"
  ],
  "scripts": {
    "build": "tsup",
    "prepublishOnly": "npm run build",
    "lint": "tsc --noEmit"
  },
  "keywords": [
    "a11y",
    "accessibility",
    "tabs",
    "component",
    "typescript",
    "utility"
  ],
  "author": "Yusuke Kamiyamane",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/y14e/tabs.git"
  },
  "bugs": {
    "url": "https://github.com/y14e/tabs/issues"
  },
  "homepage": "https://github.com/y14e/tabs#readme",
  "devDependencies": {
    "@y14e/attributes-utils": "^1.0.0",
    "bun-types": "latest",
    "tsup": "^8.0.0",
    "typescript": "^5.6.0",
    "utility-types": "^3.11.0"
  },
  "engines": {
    "node": ">=18"
  }
}
